<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EduClick</title>

    <link rel="stylesheet" href="~/css/site.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap"
          rel="stylesheet">

</head>

<body>

    <!-- NAVBAR -->
    <header class="navbar">

        <div class="logo">

            <img src="~/imagenes/icono.png" alt="Logo EduClick" />

            <span>EduClick</span>

        </div>

        <nav class="menu">

            <a asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-house"></i>
                <span>Inicio</span>
            </a>

            <a asp-controller="Actividades" asp-action="Index">
                <i class="fa-solid fa-book-open"></i>
                <span>Actividades</span>
            </a>

            <a asp-controller="Recursos" asp-action="Index">
                <i class="fa-solid fa-box"></i>
                <span>Recursos</span>
            </a>

            <a asp-controller="Galeria" asp-action="Index">
                <i class="fa-solid fa-image"></i>
                <span>Galería</span>
            </a>

            <a asp-controller="Home" asp-action="Contacto">
                <i class="fa-solid fa-envelope"></i>
                <span>Contacto</span>
            </a>

        </nav>

        <div class="actions">

            <a asp-controller="Usuario" asp-action="Inicio" class="btn login">
                <i class="fa-solid fa-user"></i>
                Iniciar sesión
            </a>

            <a asp-controller="Account" asp-action="Register" class="btn register">
                <i class="fa-solid fa-user-plus"></i>
                Registro
            </a>

        </div>

    </header>


    <!-- CONTENIDO -->
    <main>
        @RenderBody()
    </main>


    <!-- SCRIPTS -->
    <script src="~/js/site.js"></script>

</body>

</html>

